# ── Banco de dados ─────────────────────────────────────────────────────────
DB_NAME=meicompleto
DB_USER=meicompleto
DB_PASS=TROQUE_SENHA_FORTE_AQUI

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASS=TROQUE_REDIS_SENHA_AQUI

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=GERE_COM_openssl_rand_hex_64
JWT_EXPIRES_IN=30d

# ── URLs públicas ──────────────────────────────────────────────────────────
VITE_API_URL=http://10.0.111.7:4001
VITE_APP_URL=http://10.0.111.7:3002
CORS_ORIGIN=http://10.0.111.7:3002

# ── AWS SES (email) ────────────────────────────────────────────────────────
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=sa-east-1
AWS_SES_CONFIGURATION_SET=meicompleto-tracking
AGENDA_FROM_EMAIL=agenda@meicompleto.com.br

# ── Core Financeiro ───────────────────────────────────────────────────────
FINANCEIRO_FROM_EMAIL=financeiro@meicompleto.com.br
LIMITE_ANUAL_MEI_CENTS=8100000
APP_URL=https://app.meicompleto.com.br

# ── S3 para comprovantes DAS (FINF-043) ──────────────────────────────────
# Usa mesmas credenciais AWS SES acima
AWS_S3_BUCKET=meicompleto-docs
AWS_S3_REGION=sa-east-1

# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
