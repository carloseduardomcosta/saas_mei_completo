# ── Banco de dados ─────────────────────────────────────────────────────────
DB_NAME=meicompleto
DB_USER=meicompleto
DB_PASS=TROQUE_SENHA_FORTE_AQUI

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASS=TROQUE_REDIS_SENHA_AQUI

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=GERE_COM_openssl_rand_hex_64
JWT_EXPIRES_IN=30d

# ── URLs públicas ──────────────────────────────────────────────────────────
VITE_API_URL=http://10.0.111.7:4001
VITE_APP_URL=http://10.0.111.7:3002
CORS_ORIGIN=http://10.0.111.7:3002

# ── AWS SES (email) ────────────────────────────────────────────────────────
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=sa-east-1
AWS_SES_CONFIGURATION_SET=meicompleto-tracking
AGENDA_FROM_EMAIL=agenda@meicompleto.com.br

# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
